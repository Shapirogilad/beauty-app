# Copy this file to .env and fill in the values.
# For EAS builds, set these as Environment Variables in expo.dev dashboard
# (Project → Environment Variables) — do NOT commit .env

# Your server's public URL (without trailing slash)
# For beta: use ngrok, Railway, Render, etc.
API_BASE_URL=https://your-server.com/api/v1

# Tranzila payment terminal name (from Tranzila dashboard)
TRANZILA_TERMINAL=your_terminal_name

# Your EAS project ID (from expo.dev → project page, or `eas init` output)
EAS_PROJECT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

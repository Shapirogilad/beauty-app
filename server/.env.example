# ── Database ──────────────────────────────────────────────────────────────────
# Railway auto-injects DATABASE_URL when you add a Postgres plugin.
# For local dev use your local Postgres connection string.
DATABASE_URL="postgresql://postgres:password@localhost:5432/dura_dev"

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET="change-me-in-production-use-a-long-random-string"
JWT_EXPIRES_IN="7d"

# ── Firebase Admin (OTP verification) ─────────────────────────────────────────
# Get these from Firebase Console → Project Settings → Service Accounts
FIREBASE_PROJECT_ID=""
FIREBASE_CLIENT_EMAIL=""
FIREBASE_PRIVATE_KEY=""

# ── Tranzila (Israeli payment processor) ──────────────────────────────────────
TRANZILA_TERMINAL=""
TRANZILA_PASSWORD=""

# ── Server ────────────────────────────────────────────────────────────────────
# Railway sets PORT automatically — do not override it in Railway env vars.
PORT=3000
NODE_ENV=production
